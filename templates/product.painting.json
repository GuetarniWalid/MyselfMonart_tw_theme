      "name": "t:sections.image-with-text.presets.name",
      "settings": {
        "image": "shopify://shop_images/texture-tableau-toile-poster-alluminium-plexiglass.jpg",
        "title": "La finition qui reflète votre style",
        "description": "<h5>⭐ La finition qui reflète votre style</h5><p><br/>Chaque matière révèle une ambiance unique : la douceur d’une <strong>toile au toucher artisanal</strong>, l’éclat raffiné du <strong>plexiglass</strong>, ou la profondeur élégante de <strong>l’aluminium mat</strong>.<br/><br/><strong>À vous de choisir la finition qui sublime votre pièce et raconte votre style.<br/></strong></p>",
        "layout": "text_first",
        "enable_blob": true,
        "activate_dynamic_color": false,
        "dynamic_primary_color": "#111111",
        "dynamic_secondary_color": "#e3fae1",
        "padding_top": "pt-16",
