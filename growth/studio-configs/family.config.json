{
  "version": 1,
  "productType": "family-lineart",
  "steps": [
    {
      "name": "photo",
      "type": "photo",
      "required": true,
      "consent": {
        "required": true
      },
      "payloadKey": "photo",
      "title": {
        "fr": "Votre photo de famille",
        "en": "Your family photo"
      },
      "checkpointLabel": {
        "fr": "Photo",
        "en": "Photo"
      },
      "faceAngle": "back",
      "examples": {
        "good": {
          "image": "studio-photo-exemple-famille-bon-dos.jpg",
          "alt": {
            "fr": "Exemple de bonne photo : famille de dos, en pied, se tenant la main, silhouettes nettes",
            "en": "Good photo example: family from behind, full-length, holding hands, sharp silhouettes"
          }
        },
        "bad": {
          "image": "studio-photo-exemple-famille-mauvais-selfie.jpg",
          "alt": {
            "fr": "Exemple de photo à éviter : selfie serré, visages coupés, silhouettes invisibles",
            "en": "Photo to avoid: tight selfie, cropped faces, no silhouettes visible"
          },
          "caption": {
            "fr": "À éviter : selfie serré, on ne voit pas les silhouettes",
            "en": "Avoid: tight selfie, silhouettes not visible"
          }
        }
      },
      "photoCheck": true,
      "photoPolicy": {
        "subject": "group",
        "framing": "full-body",
        "people": {
          "min": 1,
          "max": 6
        },
        "angles": {
          "back": "perfect",
          "front": "warn",
          "three-quarter": "warn",
          "profile": "warn"
        },
        "messages": {
          "warn_angle": {
            "fr": "Photo acceptée — pour un dessin fidèle des silhouettes et des tailles, préférez une photo de dos, en pied.",
            "en": "Photo accepted â for a faithful drawing of silhouettes and heights, prefer a photo from behind, full-length."
          },
          "reject_framing": {
            "fr": "On ne voit pas tout le monde en entier : reprenez une photo des pieds à la tête.",
            "en": "Not everyone is fully visible: retake a photo from head to toe."
          }
        }
      }
    },
    {
      "name": "familyName",
      "type": "text",
      "required": true,
      "maxLength": 24,
      "charset": "free",
      "payloadKey": "familyName",
      "cartProperty": {
        "label": {
          "fr": "Nom de famille",
          "en": "Family name"
        }
      },
      "title": {
        "fr": "Votre nom de famille",
        "en": "Your family name"
      },
      "label": {
        "fr": "Nom affiché sous le dessin",
        "en": "Name shown under the artwork"
      },
      "placeholder": {
        "fr": "Ex : Guetarni",
        "en": "E.g. Guetarni"
      },
      "checkpointLabel": {
        "fr": "Nom",
        "en": "Name"
      }
    },
    {
      "name": "memberNames",
      "type": "text",
      "required": true,
      "maxLength": 140,
      "charset": "free",
      "payloadKey": "names",
      "cartProperty": {
        "label": {
          "fr": "Prénoms",
          "en": "First names"
        }
      },
      "title": {
        "fr": "Les prénoms, dans l'ordre",
        "en": "The names, in order"
      },
      "label": {
        "fr": "Prénoms de gauche à droite, séparés par des virgules",
        "en": "Names left to right, separated by commas"
      },
      "placeholder": {
        "fr": "Ex : Papa, Franco, Maman, Veronica",
        "en": "E.g. Daddy, Franco, Mommy, Veronica"
      },
      "help": {
        "fr": "Dans le même ordre que sur votre photo (de gauche à droite).",
        "en": "Same order as on your photo (left to right)."
      },
      "checkpointLabel": {
        "fr": "Prénoms",
        "en": "Names"
      }
    },
    {
      "name": "format",
      "type": "format",
      "required": true,
      "title": {
        "fr": "Format et finition",
        "en": "Format and finish"
      },
      "checkpointLabel": {
        "fr": "Format",
        "en": "Format"
      },
      "roles": [
        {
          "role": "size",
          "payloadKey": "format",
          "resolve": "dimensions"
        },
        {
          "role": "frame",
          "payloadKey": "frame",
          "resolve": "slug"
        }
      ]
    }
  ],
  "payload": {
    "extra": {
      "consent": "1"
    }
  }
}
