{%- liquid
  assign visible_review_count = 0
  for block in section.blocks
    if block.settings.message != blank
      assign visible_review_count = visible_review_count | plus: 1
    endif
  endfor
-%}

{%- if section.settings.title != blank -%}
  <h2 class="mx-4 md:text-center mb-12">
    <span class="title-highlight">{{ section.settings.title }}</span>
  </h2>
{%- endif -%}

{%- if visible_review_count > 0 -%}
  <div class="px-4">
    <snap-carrousel role="region" aria-label="Témoignages clients">
      <ul class="component-carroussel flex gap-4 md:gap-6 overflow-x-auto snap-mandatory snap-x scroll-smooth scrollbar-hidden py-2">
        {%- for block in section.blocks -%}
          {%- if block.settings.message != blank -%}
            {% render 'customer-testimonial-card', block: block, forloop: forloop %}
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </snap-carrousel>
  </div>

  {% render 'customer-testimonial-schema', section_blocks: section.blocks, product: product %}

  <script src="{{ 'component-carrousel.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.customer-testimonial.name",
  "tag": "section",
  "class": "page-width my-16",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.customer-testimonial.settings.title.label",
      "default": "Our customers are delighted"
    }
  ],
  "blocks": [
    {
      "type": "image-text",
      "name": "t:sections.customer-testimonial.blocks.image-text.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.customer-testimonial.blocks.image-text.settings.image.label"
        },
        {
          "type": "textarea",
          "id": "message",
          "label": "t:sections.customer-testimonial.blocks.image-text.settings.message.label",
          "default": "Just a little photo to say a big thank you to you 🥰. Elodie G"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.customer-testimonial.name",
      "blocks": [
        {
          "type": "image-text"
        }
      ]
    }
  ]
}
{% endschema %}
