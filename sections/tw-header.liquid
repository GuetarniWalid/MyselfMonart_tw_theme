<script src="{{ 'tw-header.js' | asset_url }}" defer="defer"></script>
{% if template.name != 'cart' %}
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% render 'tw-sticky-header' %}
{% if template.name != 'search' %}
  {% render 'tw-predictive-search'
    , in_header: true %}
{% endif %}

{%- if request.page_type == 'index' -%}
  {%- assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" -%}
  {% comment %}
    Organization schema is emitted by the trust-signals section so it can
    include aggregateRating + review[] alongside logo + sameAs in a single
    consolidated entity. WebSite stays here.
  {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
  {
    "name": "t:sections.header.name",
    "tag": "header",
    "class": "sticky top-0 z-40 translate-y-0 transition-transform duration-150",
    "settings": [
      {
        "type": "html",
        "id": "logo_svg",
        "label": "t:sections.header.settings.logo_svg.label",
        "info": "t:sections.header.settings.logo_svg.info"
      },
      {
        "type": "image_picker",
        "id": "default_desktop_image_1",
        "label": "t:sections.header.settings.default_desktop_image_1.label",
        "info": "t:sections.header.settings.default_desktop_image_1.info"
      },
      {
        "type": "image_picker",
        "id": "default_desktop_image_2",
        "label": "t:sections.header.settings.default_desktop_image_2.label"
      },
      {
        "type": "image_picker",
        "id": "default_desktop_image_3",
        "label": "t:sections.header.settings.default_desktop_image_3.label"
      },
      {
        "type": "image_picker",
        "id": "default_desktop_image_4",
        "label": "t:sections.header.settings.default_desktop_image_4.label"
      }
    ],
    "blocks": [ 
      {
        "type": "collection_only",
        "name": "t:sections.header.blocks.collection_only.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "desktop_image_1",
            "label": "t:sections.header.blocks.collection_only.settings.desktop_image_1.label",
            "info": "t:sections.header.blocks.collection_only.settings.desktop_image_1.info"
          },
          {
            "type": "image_picker",
            "id": "desktop_image_2",
            "label": "t:sections.header.blocks.collection_only.settings.desktop_image_2.label"
          },
          {
            "type": "image_picker",
            "id": "desktop_image_3",
            "label": "t:sections.header.blocks.collection_only.settings.desktop_image_3.label"
          },
          {
            "type": "image_picker",
            "id": "desktop_image_4",
            "label": "t:sections.header.blocks.collection_only.settings.desktop_image_4.label"
          },
          {
            "type": "collection",
            "id": "collection",
            "label": "t:sections.header.blocks.collection_only.settings.collection.label"
          }
        ]
      },
      {
        "type": "product_only",
        "name": "t:sections.header.blocks.product_only.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "t:sections.header.blocks.product_only.settings.desktop_image.label",
            "info": "t:sections.header.blocks.product_only.settings.desktop_image.info"
          },
          {
            "type": "product",
            "id": "product",
            "label": "t:sections.header.blocks.product_only.settings.product.label"
          }
        ]
      },
      {
        "type": "page_only",
        "name": "t:sections.header.blocks.page_only.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "t:sections.header.blocks.page_only.settings.desktop_image.label",
            "info": "t:sections.header.blocks.page_only.settings.desktop_image.info"
          },
          {
            "type": "page",
            "id": "page",
            "label": "t:sections.header.blocks.page_only.settings.page.label"
          }
        ]
      },
      {
        "type": "title_only",
        "name": "t:sections.header.blocks.title_only.name",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.header.blocks.title_only.settings.title.label",
            "default": "Title"
          }
        ]
      },
      {
        "type": "set_of_collections",
        "name": "t:sections.header.blocks.parent_collection.name.images",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.header.blocks.parent_collection.settings.title.label",
            "default": "Title of collections"
          },
          {
            "type": "collection_list",
            "id": "child_collection_list",
            "label": "t:sections.header.blocks.parent_collection.settings.child_collection_list.label"
          },
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "t:sections.header.blocks.parent_collection.settings.desktop_image.label",
            "info": "t:sections.header.blocks.parent_collection.settings.desktop_image.info"
          }
        ]
      }
    ]
  }
{% endschema %}