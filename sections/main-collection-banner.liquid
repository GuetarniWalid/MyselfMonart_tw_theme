<h1 class="py-8">{{ collection.title | escape }}</h1>
{%- comment -%}
  Rollout éditorial metafield-first : si custom.guide existe, le guide éditorial (rendu sous la grille
  par collection-editorial-auto) remplace la description — on ne l'affiche pas ici en doublon
  (évite 2 zones de gros texte ; cf tableau-salon = 1 seule zone). Le H1 ci-dessus reste toujours rendu.
  Description PRÉSERVÉE dans Shopify, ré-affichée automatiquement si custom.guide est vidé.
{%- endcomment -%}
{%- if section.settings.show_description and collection.metafields.custom.guide == blank -%}
<div class="collection-description dropdown-button-target{% if section.settings.show_collapse_button %} h-56 overflow-hidden relative after:absolute after:bottom-0 after:w-full after:h-20 after:bg-gradient-to-t after:from-secondary{% endif %}">{{ collection.description }}</div>
{%- if section.settings.show_collapse_button -%}
  <dropdown-button>
    <button class="group mt-6">{{ 'sections.main_collection_banner.learn_more' | t }} &nbsp; {%- render 'tw-icon-arrow' -%}</button>
    <button class="group mt-2 hidden">{{ 'sections.main_collection_banner.fewer_details' | t }} &nbsp; {%- render 'tw-icon-arrow' -%}</button>
  </dropdown-button>
{%- endif -%}
{%- endif -%}

{% if section.settings.to_place_first %}
  <style>
    .main-collection-banner {
      order: 1;
    }
  </style>
{% endif %}

{% schema %}
  {
    "name": "t:sections.main-collection-banner.name",
    "class": "main-collection-banner page-width mb-14 px-4",
    "tag": "section",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_description",
        "default": true,
        "label": "Afficher la description de la collection",
        "info": "Décocher pour n'afficher que le H1 (ex : quand la description est rendue dans une section éditoriale dédiée plus bas)."
      },
      {
        "type": "checkbox",
        "id": "show_collapse_button",
        "default": false,
        "label": "t:sections.main-collection-banner.settings.show_collapse_button.label",
        "info": "t:sections.main-collection-banner.settings.show_collapse_button.info"
      },
      {
        "type": "header",
        "content": "SEO"
      },
      {
        "type": "checkbox",
        "id": "to_place_first",
        "default": false,
        "label": "t:sections.main-collection-banner.settings.to_place_first.label",
        "info": "t:sections.main-collection-banner.settings.to_place_first.info"
      }
    ]
  }
{% endschema %}