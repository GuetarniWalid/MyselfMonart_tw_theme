{%- comment -%}
  Home — Editorial Cocon (section texte H2.1 Bienvenue).

  Conventions appliquées (cf .claude/skills/shopify-section-dev) :
  - Tailwind only — pas de CSS custom, pas de <style>
  - Variables globales theme : bg-main-5, text-main, text-main-70,
    text-buy-button, font-heading, font-roboto
  - Admin-configurable via {% schema %}
  - SEO : heading_level configurable, id unique, aria-labelledby
  - A11y : <blockquote> sémantique, ornement aria-hidden, motion-reduce
  - Inspiration : Aesop (whitespace + serif), NYT Magazine (drop cap +
    pull quote), Vignelli (asymétrie maîtrisée), Off-White (eyebrow numéroté)
  - enabled_on.templates = ['index']

  Architecture layout : container max-w-3xl mx-auto pour un rythme de
  lecture éditorial. Asymétrie obtenue par décalages margin négatifs
  ponctuels (pas de grid 12 cols qui causait des rangées vides).
{%- endcomment -%}

{%- liquid
  case section.settings.background_color
    when 'cream'
      assign bg_class = 'bg-main-5'
    when 'sable'
      assign bg_class = 'bg-main-10'
    when 'secondary'
      assign bg_class = 'bg-secondary'
    when 'dark'
      assign bg_class = 'bg-main'
    else
      assign bg_class = 'bg-main-5'
  endcase

  assign text_class = 'text-main'
  assign muted_class = 'text-main-70'
  assign quote_border = 'border-buy-button'
  assign drop_cap_class = 'text-buy-button'
  if section.settings.background_color == 'dark'
    assign text_class = 'text-secondary'
    assign muted_class = 'text-secondary-50'
    assign quote_border = 'border-secondary'
  endif

  assign heading_level = section.settings.heading_level | default: 'h2'
  assign heading_id = 'home-editorial-cocon-' | append: section.id
-%}

<section
  class="home-editorial-cocon {{ bg_class }} {{ text_class }} w-full py-20 md:py-28 lg:py-36"
  aria-labelledby="{{ heading_id }}">

  <div class="max-w-3xl mx-auto px-6 md:px-8">

    {%- comment -%} Eyebrow numéroté façon Aesop / Off-White {%- endcomment -%}
    {%- if section.settings.eyebrow_number != blank or section.settings.eyebrow_label != blank -%}
      <p class="font-roboto text-xs tracking-[0.22em] uppercase {{ muted_class }} flex items-center gap-3 mb-8 md:mb-10">
        {%- if section.settings.eyebrow_number != blank -%}
          <span class="font-heading text-sm normal-case tracking-normal {{ text_class }}">— {{ section.settings.eyebrow_number | escape }}</span>
        {%- endif -%}
        {%- if section.settings.eyebrow_label != blank -%}
          <span aria-hidden="true" class="block h-px w-8 bg-current opacity-40"></span>
          <span>{{ section.settings.eyebrow_label | escape }}</span>
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- comment -%} H2 — légèrement décalé à gauche (-ml-1 sur md, statement subtil) {%- endcomment -%}
    {%- if section.settings.h2_title != blank -%}
      <{{ heading_level }}
        id="{{ heading_id }}"
        class="font-heading {{ text_class }} !text-3xl md:!text-4xl lg:!text-5xl leading-[1.1] tracking-tight mb-10 md:mb-14 max-w-2xl">
        {{ section.settings.h2_title }}
      </{{ heading_level }}>
    {%- endif -%}

    {%- comment -%}
      Paragraphe 1 — drop cap éditorial via .drop-cap (input.css @layer components).
      Cible automatiquement la première lettre du premier <p> rendu par le richtext.
    {%- endcomment -%}
    {%- if section.settings.paragraph_1 != blank -%}
      <div class="drop-cap font-roboto text-lg md:text-xl leading-relaxed {{ muted_class }} mb-12 md:mb-16 [&>p+p]:mt-4 [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-buy-button motion-reduce:[&_a]:transition-none [&_strong]:{{ text_class }} [&_strong]:font-semibold">
        {{ section.settings.paragraph_1 }}
      </div>
    {%- endif -%}

    {%- comment -%}
      Pull quote — bordure latérale terracotta, italic, décalée à gauche
      sur desktop (margin-left négatif pour sortir du container, effet
      "callout magazine"). Largeur contenue pour rester lisible.
    {%- endcomment -%}
    {%- if section.settings.pull_quote != blank -%}
      <blockquote class="my-12 md:my-16 lg:-ml-12 max-w-xl pl-6 md:pl-8 border-l-4 {{ quote_border }} font-heading italic !text-xl md:!text-2xl lg:!text-3xl leading-snug {{ text_class }}">
        <p class="mb-3">« {{ section.settings.pull_quote }} »</p>
        {%- if section.settings.pull_quote_attribution != blank -%}
          <footer class="font-roboto not-italic text-xs tracking-[0.18em] uppercase {{ muted_class }} mt-3">— {{ section.settings.pull_quote_attribution | escape }}</footer>
        {%- endif -%}
      </blockquote>
    {%- endif -%}

    {%- comment -%} Paragraphe 2 — décalé à droite (margin-left positif) pour asymétrie {%- endcomment -%}
    {%- if section.settings.paragraph_2 != blank -%}
      <div class="font-roboto text-lg md:text-xl leading-relaxed {{ muted_class }} mb-12 md:mb-16 md:pl-12 lg:pl-20
                  [&>p+p]:mt-4
                  [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-buy-button motion-reduce:[&_a]:transition-none
                  [&_strong]:{{ text_class }} [&_strong]:font-semibold">
        {{ section.settings.paragraph_2 }}
      </div>
    {%- endif -%}

    {%- comment -%} Ornement décoratif central — séparateur éditorial classique {%- endcomment -%}
    {%- if section.settings.show_ornament -%}
      <div class="flex justify-center my-10 md:my-14" aria-hidden="true">
        <span class="font-heading text-2xl md:text-3xl {{ drop_cap_class }}">{{ section.settings.ornament_symbol | default: '❋' }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Closing signature italique centrée — signature poétique {%- endcomment -%}
    {%- if section.settings.closing_signature != blank -%}
      <p class="text-center font-heading italic !text-lg md:!text-xl lg:!text-2xl leading-snug {{ text_class }} max-w-2xl mx-auto">
        {{ section.settings.closing_signature }}
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Home — Editorial cocon",
  "tag": "section",
  "class": "home-editorial-cocon-section",
  "enabled_on": { "templates": ["index"] },
  "settings": [
    {
      "type": "header",
      "content": "Eyebrow (étiquette)"
    },
    {
      "type": "text",
      "id": "eyebrow_number",
      "label": "Numéro (ex : 01)",
      "info": "Style Aesop : « — 01    BIENVENUE »",
      "default": "01"
    },
    {
      "type": "text",
      "id": "eyebrow_label",
      "label": "Label (capitales)",
      "default": "Bienvenue"
    },
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Niveau du titre (SEO)",
      "info": "h2 par défaut. h1 réservé à la home (si on déplace le hero ailleurs).",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "textarea",
      "id": "h2_title",
      "label": "Titre principal",
      "default": "Bienvenue dans le cocon MyselfMonArt"
    },
    {
      "type": "header",
      "content": "Paragraphe 1 (avec drop cap automatique)"
    },
    {
      "type": "paragraph",
      "content": "La première lettre du premier paragraphe est automatiquement rendue en très grande taille (lettrine style magazine)."
    },
    {
      "type": "richtext",
      "id": "paragraph_1",
      "label": "Texte",
      "default": "<p>Il y a un instant que vous connaissez bien. Celui où vous rentrez chez vous, où la porte se referme, et où le monde se met enfin en sourdine.</p><p>C'est cet instant-là que nous habillons.</p>"
    },
    {
      "type": "header",
      "content": "Pull quote (citation extraite)"
    },
    {
      "type": "textarea",
      "id": "pull_quote",
      "label": "Citation",
      "info": "Affichée avec bordure latérale terracotta, italique, décalée à gauche. Sans les guillemets — ils sont ajoutés automatiquement.",
      "default": "Un mur n'est jamais juste un mur."
    },
    {
      "type": "text",
      "id": "pull_quote_attribution",
      "label": "Attribution (optionnel)",
      "info": "Ex : « Hayate », « Notre direction artistique »"
    },
    {
      "type": "header",
      "content": "Paragraphe 2"
    },
    {
      "type": "richtext",
      "id": "paragraph_2",
      "label": "Texte",
      "default": "<p>Depuis 2022, nous sélectionnons à la main, retouchons œuvre par œuvre, et livrons des tableaux pensés pour les intérieurs qui veulent <strong>respirer plus large</strong>. Pas de catalogue de masse, pas de collections impersonnelles : seulement ce que notre direction artistique a jugé digne d'entrer chez vous.</p>"
    },
    {
      "type": "header",
      "content": "Ornement décoratif"
    },
    {
      "type": "checkbox",
      "id": "show_ornament",
      "label": "Afficher l'ornement séparateur",
      "default": true
    },
    {
      "type": "text",
      "id": "ornament_symbol",
      "label": "Symbole",
      "info": "Ex : ❋ ✦ — ◆ ✷",
      "default": "❋"
    },
    {
      "type": "header",
      "content": "Signature de clôture (poétique)"
    },
    {
      "type": "textarea",
      "id": "closing_signature",
      "label": "Phrase de clôture italique",
      "info": "Affichée en italique centré.",
      "default": "Prenez le temps. Le bon tableau, c'est rarement le premier — c'est celui qui revient vous chercher."
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "cream",
      "options": [
        { "value": "secondary", "label": "Secondary (blanc cassé)" },
        { "value": "cream",     "label": "Main 5% (sable doux)" },
        { "value": "sable",     "label": "Main 10% (sable plus marqué)" },
        { "value": "dark",      "label": "Main (fond sombre, texte clair)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home — Editorial cocon",
      "settings": {
        "eyebrow_number": "01",
        "eyebrow_label": "Bienvenue",
        "h2_title": "Bienvenue dans le cocon MyselfMonArt",
        "show_ornament": true,
        "ornament_symbol": "❋"
      }
    }
  ]
}
{% endschema %}
