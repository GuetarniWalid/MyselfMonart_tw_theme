<section class="home-section home-customers">
  <div class="home-customers__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="home-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="home-h2">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="home-lead" style="color: rgba(245,240,232,0.85);">{{ section.settings.lead | escape }}</p>
    {%- endif -%}
    {%- if section.settings.review_count and section.settings.review_count > 0 -%}
      <p class="home-customers__count">
        {{ section.settings.review_count }} retours vérifiés sur Trustpilot
        {%- if section.settings.trustpilot_link != blank %} · <a href="{{ section.settings.trustpilot_link }}" target="_blank" rel="noopener">Voir tous nos avis</a>{% endif -%}
      </p>
    {%- endif -%}
  </div>

  <div class="home-customers__track" role="region" aria-label="Avis clients">
    {%- for block in section.blocks -%}
      {%- liquid
        assign img_url = ''
        if block.settings.image != blank
          assign img_url = block.settings.image | image_url: width: 700
        elsif block.settings.image_asset != blank
          assign img_url = block.settings.image_asset | asset_url
        endif

        assign normalized = block.settings.message | strip
        assign words = normalized | split: ' '
        assign word_count = words.size
        assign author = ''
        assign body = normalized
        if word_count >= 2
          assign last_i = word_count | minus: 1
          assign penul = word_count | minus: 2
          assign author = words[penul] | append: ' ' | append: words[last_i]
          assign body_size = normalized | size
          assign author_size = author | size
          assign keep = body_size | minus: author_size
          assign body = normalized | truncate: keep, '' | strip
        endif
      -%}
      <article class="home-customer" {{ block.shopify_attributes }}>
        {%- if img_url != '' -%}
          <div class="home-customer__image-wrap">
            <img class="home-customer__image"
              src="{{ img_url }}"
              alt="Tableau accroché chez un client MyselfMonArt"
              loading="lazy"
              decoding="async">
          </div>
        {%- endif -%}
        {%- if body != blank -%}
          <p class="home-customer__message">{{ body }}</p>
        {%- endif -%}
        {%- if author != blank -%}
          <p class="home-customer__author">— {{ author }}</p>
        {%- endif -%}
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Home — Customers carousel",
  "tag": "section",
  "enabled_on": { "templates": ["index"] },
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ils nous font confiance" },
    { "type": "text", "id": "title", "label": "Titre H2", "default": "Ce que vivent nos clients au quotidien" },
    { "type": "textarea", "id": "lead", "label": "Lead" },
    { "type": "number", "id": "review_count", "label": "Nombre d'avis Trustpilot", "default": 80 },
    { "type": "url", "id": "trustpilot_link", "label": "Lien Trustpilot" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo client" },
        { "type": "text", "id": "image_asset", "label": "OU asset filename" },
        { "type": "textarea", "id": "message", "label": "Message (le nom du client en 2 derniers mots)" }
      ]
    }
  ],
  "presets": [
    { "name": "Home — Customers", "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }] }
  ]
}
{% endschema %}
