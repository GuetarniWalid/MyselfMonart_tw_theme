      "default": "h2",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Taille du titre",
      "info": "Medium (par défaut) s'aligne sur les autres H2 du theme. Large pour la home (titre éditorial). Small pour un sous-bloc.",
      "default": "medium",
      "options": [
        { "value": "small",  "label": "Small (xl → 2xl)" },
        { "value": "medium", "label": "Medium (2xl → 3xl → 36px)" },
        { "value": "large",  "label": "Large (32px → 44px → 56px)" }
      ]
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "info": "Semibold (par défaut) s'aligne sur les autres H2 du theme.",
      "default": "semibold",
      "options": [
        { "value": "light",    "label": "Light (300)" },
        { "value": "normal",   "label": "Normal (400)" },
        { "value": "medium",   "label": "Medium (500)" },
        { "value": "semibold", "label": "Semibold (600)" },
        { "value": "bold",     "label": "Bold (700)" }
      ]
