      "default": "terra",
      "options": [
        { "value": "terra",      "label": "Terra (terracotta foncé — défaut)" },
        { "value": "buy-button", "label": "Buy button (= bouton Panier)" },
        { "value": "brand-900",  "label": "Brand 900 (terracotta chocolat)" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collapsible_content.settings.heading.label",
      "default": "Questions fréquentes"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead (optionnel)"
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "secondary",
      "options": [
        { "value": "secondary",   "label": "Secondary (blanc cassé)" },
        { "value": "cream",       "label": "Main 5% (sable doux)" },
        { "value": "sable",       "label": "Main 10% (sable marqué)" },
        { "value": "transparent", "label": "Transparent (hérite du parent)" }
      ]
    },
    {
      "type": "select",
      "id": "padding_size",
      "label": "Espacement vertical",
      "default": "large",
      "options": [
        { "value": "small",  "label": "Petit" },
        { "value": "medium", "label": "Moyen" },
        { "value": "large",  "label": "Grand (défaut)" }
      ]
    },
    {
      "type": "header",
      "content": "SEO"
    },
    {
      "type": "checkbox",
      "id": "emit_faq_jsonld",
      "label": "Émettre JSON-LD FAQPage",
