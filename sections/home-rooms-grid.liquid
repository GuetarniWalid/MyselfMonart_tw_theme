{%- comment -%}
  Home — Rooms Grid (H2.3 Trouver votre tableau selon la pièce).

  Conventions appliquées (cf .claude/skills/shopify-section-dev) :
  - Tailwind only — pas de CSS custom (refonte de home-cards-grid V2 qui
    utilisait home-styles.css)
  - Variables globales : bg-main-5, bg-secondary, text-main, text-main-70,
    text-buy-button, font-heading, font-roboto
  - Admin-configurable : eyebrow numéroté + h2 + intro + 6 blocks de pièce
    (chacun : numéro éditorial, image_picker OU asset, alt, label, titre,
    texte court, lien)
  - SEO : H2 unique avec id + aria-labelledby ; H3 sur chaque pièce ;
    heading_level section configurable ; srcset Shopify quand image_picker
  - A11y : card-as-link avec focus-visible:ring, motion-reduce sur transitions,
    chiffre décoratif aria-hidden, alt obligatoire (mention info dans schema)
  - enabled_on.templates = ['index']

  Améliorations vs V1 home-cards-grid :
  - Numéro éditorial "01" "02" en absolute top-left sur l'image (font-heading
    italic + text-secondary + drop-shadow) — style NYT Magazine chapter pages
    au lieu du label pill "SALON" qui faisait e-commerce générique
  - Cohérence eyebrow numéroté avec home-editorial-cocon (01) et
    home-usps-bento (02) → cette section est "03"
  - Lien hover : translate-x sur la flèche (micro-interaction premium)
  - Image scale au hover : 1.03 (subtle, pas 1.05+ qui fait gimmicky)
{%- endcomment -%}

{%- liquid
  case section.settings.background_color
    when 'cream'
      assign bg_class = 'bg-main-5'
    when 'sable'
      assign bg_class = 'bg-main-10'
    when 'secondary'
      assign bg_class = 'bg-secondary'
    when 'dark'
      assign bg_class = 'bg-main'
    else
      assign bg_class = 'bg-main-5'
  endcase

  assign text_class = 'text-main'
  assign muted_class = 'text-main-70'
  assign link_class = 'text-buy-button'
  assign number_overlay_class = 'text-secondary'
  if section.settings.background_color == 'dark'
    assign text_class = 'text-secondary'
    assign muted_class = 'text-secondary-50'
    assign number_overlay_class = 'text-secondary'
  endif

  assign heading_level = section.settings.heading_level | default: 'h2'
  assign heading_id = 'home-rooms-grid-' | append: section.id

  assign cols_class = 'lg:grid-cols-3'
  case section.settings.columns
    when '2'
      assign cols_class = 'lg:grid-cols-2'
    when '4'
      assign cols_class = 'lg:grid-cols-4'
  endcase
-%}

<section
  class="home-rooms-grid {{ bg_class }} {{ text_class }} w-full py-20 md:py-28 lg:py-36"
  aria-labelledby="{{ heading_id }}">

  <div class="max-w-6xl mx-auto px-6 md:px-8">

    {%- comment -%} Header : eyebrow numéroté + H2 + intro (cohérent avec cocon & bento) {%- endcomment -%}
    <div class="text-center mb-14 md:mb-20">

      {%- if section.settings.eyebrow_number != blank or section.settings.eyebrow_label != blank -%}
        <p class="font-roboto text-xs tracking-[0.22em] uppercase {{ muted_class }} flex items-center justify-center gap-3 mb-6 md:mb-8">
          {%- if section.settings.eyebrow_number != blank -%}
            <span class="font-heading text-sm normal-case tracking-normal {{ text_class }}">— {{ section.settings.eyebrow_number | escape }}</span>
          {%- endif -%}
          {%- if section.settings.eyebrow_label != blank -%}
            <span aria-hidden="true" class="block h-px w-8 bg-current opacity-40"></span>
            <span>{{ section.settings.eyebrow_label | escape }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}

      {%- if section.settings.h2_title != blank -%}
        <{{ heading_level }}
          id="{{ heading_id }}"
          class="font-heading {{ text_class }} !text-3xl md:!text-4xl lg:!text-5xl leading-[1.1] tracking-tight mb-6 max-w-2xl mx-auto">
          {{ section.settings.h2_title }}
        </{{ heading_level }}>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <p class="font-roboto text-base md:text-lg leading-relaxed {{ muted_class }} max-w-xl mx-auto">
          {{ section.settings.intro }}
        </p>
      {%- endif -%}

    </div>

    {%- comment -%} Grille de cards {%- endcomment -%}
    <div class="grid grid-cols-1 sm:grid-cols-2 {{ cols_class }} gap-x-5 gap-y-12 md:gap-x-6 md:gap-y-16">

      {%- for block in section.blocks -%}
        {%- liquid
          assign block_number = block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2

          assign img_url = ''
          assign img_alt = block.settings.image_alt | default: ''
          assign img_width = 800
          assign img_height = 1000

          if block.settings.image != blank
            assign img_url = block.settings.image | image_url: width: 800
            assign img_width = block.settings.image.width
            assign img_height = block.settings.image.height
          elsif block.settings.image_asset != blank
            assign img_url = block.settings.image_asset | asset_url
          endif

          assign has_link = false
          if block.settings.link != blank
            assign has_link = true
          endif
        -%}

        <article class="flex flex-col group" {{ block.shopify_attributes }}>

          {%- comment -%} Image wrapper avec numéro éditorial en overlay {%- endcomment -%}
          <div class="relative overflow-hidden aspect-[4/5] {{ bg_class }} mb-5">

            {%- if has_link -%}
              <a
                href="{{ block.settings.link }}"
                class="absolute inset-0 z-10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-buy-button focus-visible:ring-offset-2 focus-visible:ring-offset-secondary"
                aria-label="{{ block.settings.title | default: img_alt | escape }} — découvrir">
                <span class="sr-only">{{ block.settings.title | default: img_alt | escape }}</span>
              </a>
            {%- endif -%}

            {%- if img_url != '' -%}
              {%- if block.settings.image != blank -%}
                <img
                  srcset="{%- if block.settings.image.width >= 400 -%}{{ block.settings.image | image_url: width: 400 }} 400w,{%- endif -%}
                          {%- if block.settings.image.width >= 600 -%}{{ block.settings.image | image_url: width: 600 }} 600w,{%- endif -%}
                          {%- if block.settings.image.width >= 800 -%}{{ block.settings.image | image_url: width: 800 }} 800w,{%- endif -%}
                          {%- if block.settings.image.width >= 1000 -%}{{ block.settings.image | image_url: width: 1000 }} 1000w,{%- endif -%}
                          {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
                  sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, 33vw"
                  src="{{ img_url }}"
                  alt="{{ img_alt | escape }}"
                  width="{{ img_width }}"
                  height="{{ img_height }}"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover transition-transform duration-700 ease-out motion-reduce:transition-none group-hover:scale-[1.03]">
              {%- else -%}
                <img
                  src="{{ img_url }}"
                  alt="{{ img_alt | escape }}"
                  width="{{ img_width }}"
                  height="{{ img_height }}"
                  loading="lazy"
                  decoding="async"
                  sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, 33vw"
                  class="w-full h-full object-cover transition-transform duration-700 ease-out motion-reduce:transition-none group-hover:scale-[1.03]">
              {%- endif -%}
            {%- endif -%}

            {%- comment -%} Numéro éditorial en overlay (style NYT Magazine) {%- endcomment -%}
            {%- if section.settings.show_numbers -%}
              <div
                class="absolute top-4 left-4 md:top-6 md:left-6 z-[5] pointer-events-none font-heading italic text-3xl md:text-4xl {{ number_overlay_class }} drop-shadow-[0_2px_8px_rgba(0,0,0,0.4)]"
                aria-hidden="true">
                {{ block_number }}
              </div>
            {%- endif -%}

          </div>

          {%- comment -%} Titre + texte + lien {%- endcomment -%}
          {%- if block.settings.title != blank -%}
            <h3 class="font-heading {{ text_class }} !text-xl md:!text-2xl leading-tight mb-2">
              {{ block.settings.title | escape }}
            </h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="font-roboto text-sm md:text-base leading-relaxed {{ muted_class }} mb-3 [&_strong]:{{ text_class }} [&_strong]:font-semibold">
              {{ block.settings.text }}
            </div>
          {%- endif -%}

          {%- if has_link and block.settings.link_label != blank -%}
            <p class="mt-auto pt-1">
              <span class="font-roboto text-xs tracking-[0.18em] uppercase {{ link_class }} inline-flex items-center gap-2">
                {{ block.settings.link_label | escape }}
                <span aria-hidden="true" class="transition-transform duration-200 ease-out motion-reduce:transition-none group-hover:translate-x-1">→</span>
              </span>
            </p>
          {%- endif -%}

        </article>
      {%- endfor -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Home — Rooms grid",
  "tag": "section",
  "class": "home-rooms-grid-section",
  "enabled_on": { "templates": ["index"] },
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Eyebrow (étiquette)"
    },
    {
      "type": "text",
      "id": "eyebrow_number",
      "label": "Numéro (ex : 03)",
      "default": "03"
    },
    {
      "type": "text",
      "id": "eyebrow_label",
      "label": "Label (capitales)",
      "default": "Par pièce"
    },
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Niveau du titre (SEO)",
      "default": "h2",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "textarea",
      "id": "h2_title",
      "label": "Titre principal",
      "default": "Trouver votre tableau selon la pièce"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Chaque pièce appelle une intention différente. Commencez par la pièce, le reste suit."
    },
    {
      "type": "header",
      "content": "Grille"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Colonnes desktop",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_numbers",
      "label": "Afficher les numéros éditoriaux sur les images",
      "default": true
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "cream",
      "options": [
        { "value": "secondary", "label": "Secondary (blanc cassé)" },
        { "value": "cream",     "label": "Main 5% (sable doux)" },
        { "value": "sable",     "label": "Main 10% (sable plus marqué)" },
        { "value": "dark",      "label": "Main (fond sombre, texte clair)" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Pièce",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numéro éditorial (ex : 01)",
          "info": "Affiché en overlay sur l'image. Si vide, utilise l'index du block (01, 02, 03...)."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (recommandé — srcset auto)"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "OU asset filename (fallback)",
          "info": "Ex : vignette-salon-v1.png (doit exister dans /assets)."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt text (obligatoire SEO + a11y)",
          "info": "Décrire le contenu de l'image en 80–125 caractères."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre H3 (ex : « Tableau pour le salon »)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texte court (50–80 mots)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Lien — libellé",
          "default": "Découvrir"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien — URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home — Rooms grid",
      "blocks": [
        { "type": "room" },
        { "type": "room" },
        { "type": "room" },
        { "type": "room" },
        { "type": "room" },
        { "type": "room" }
      ]
    }
  ]
}
{% endschema %}
