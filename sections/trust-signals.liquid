{%- liquid
  assign visible_review_count = 0
  for block in section.blocks
    if block.type == 'image-text' and block.settings.message != blank
      assign visible_review_count = visible_review_count | plus: 1
    endif
  endfor

  assign score = section.settings.trustpilot_score | default: 45
  assign score_display = score | divided_by: 10.0
  assign review_count = section.settings.trustpilot_review_count | default: 0
-%}

<div class="trust-signals">
  <div class="trust-signals__intro flex flex-col items-center gap-6 md:gap-8 mx-4 md:mx-0 mb-10 md:mb-14">
    {%- if section.settings.eyebrow != blank -%}
      <p class="trust-signals__eyebrow text-sm md:text-base tracking-widest uppercase text-main-70">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="text-2xl md:text-3xl text-center max-w-2xl">
        <span class="title-highlight">{{ section.settings.title }}</span>
      </h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="text-base md:text-lg text-main-70 text-center max-w-xl leading-relaxed">
        {{ section.settings.subtitle }}
      </p>
    {%- endif -%}

    {%- if section.settings.show_trustpilot -%}
      <div class="trust-signals__trustpilot mt-2">
        {% render 'trustpilot-badge',
          score: score,
          review_count: review_count,
          link: section.settings.trustpilot_link,
          size: 'lg',
          align: 'items-center'
        %}
      </div>
    {%- endif -%}
  </div>

  {%- if visible_review_count > 0 -%}
    <div class="trust-signals__carrousel-wrapper px-4 md:px-0 relative">
      <snap-carrousel role="region" aria-label="{{ 'sections.trust-signals.carrousel_label' | t }}">
        <ul class="component-carroussel flex gap-4 md:gap-6 overflow-x-auto snap-mandatory snap-x scroll-smooth scrollbar-hidden py-2">
          {%- for block in section.blocks -%}
            {%- if block.type == 'image-text' and block.settings.message != blank -%}
              {% render 'customer-testimonial-card', block: block, forloop: forloop %}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </snap-carrousel>

      <p class="sr-only">
        {{ 'sections.trust-signals.carrousel_hint' | t: count: visible_review_count }}
      </p>
    </div>

    <script src="{{ 'component-carrousel.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if section.settings.show_trustpilot or visible_review_count > 0 -%}
    {%- liquid
      assign social_seed = ''
      if settings.social_twitter_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_twitter_link
      endif
      if settings.social_facebook_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_facebook_link
      endif
      if settings.social_instagram_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_instagram_link
      endif
      if settings.social_tiktok_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_tiktok_link
      endif
      if settings.social_tumblr_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_tumblr_link
      endif
      if settings.social_snapchat_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_snapchat_link
      endif
      if settings.social_youtube_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_youtube_link
      endif
      if settings.social_vimeo_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_vimeo_link
      endif
      if settings.social_pinterest_link != blank
        assign social_seed = social_seed | append: '|' | append: settings.social_pinterest_link
      endif
      assign social_links = social_seed | remove_first: '|' | split: '|'
    -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": {{ request.origin | json }},
        "logo": "https://cdn.shopify.com/s/files/1/0623/2388/4287/files/logo-myselfmonart-512x512.png?v=1694726914"
        {%- if social_links.size > 0 -%}
        ,
        "sameAs": [{%- for url in social_links -%}{{ url | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
        {%- endif -%}
        {%- if section.settings.show_trustpilot -%}
        ,
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ score_display }}",
          "bestRating": "5",
          "worstRating": "1",
          "ratingCount": "{{ review_count | default: 30 }}"
        }
        {%- endif -%}
        {%- if visible_review_count > 0 -%}
        ,
        "review": [
          {%- assign emitted = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type != 'image-text' or block.settings.message == blank -%}{%- continue -%}{%- endif -%}
            {%- liquid
              assign normalized = block.settings.message | newline_to_br | replace: '<br />', ' ' | replace: '<br>', ' ' | replace: '  ', ' ' | replace: '  ', ' ' | strip
              assign words = normalized | split: ' '
              assign word_count = words.size
              assign author_name = ''
              assign review_body = normalized
              if word_count >= 2
                assign last_idx = word_count | minus: 1
                assign second_last_idx = word_count | minus: 2
                assign author_name = words[second_last_idx] | append: ' ' | append: words[last_idx]
                assign body_size = normalized | size
                assign author_size = author_name | size
                assign keep = body_size | minus: author_size
                assign review_body = normalized | truncate: keep, '' | strip
              endif
            -%}
            {%- if emitted > 0 -%},{%- endif -%}
            {
              "@type": "Review",
              {%- if author_name != blank %}
              "author": {
                "@type": "Person",
                "name": {{ author_name | json }}
              },
              {%- endif %}
              "reviewBody": {{ review_body | json }},
              "reviewRating": {
                "@type": "Rating",
                "ratingValue": "5",
                "bestRating": "5",
                "worstRating": "1"
              },
              "itemReviewed": {
                "@type": "Organization",
                "name": {{ shop.name | json }}
              }
            }
            {%- assign emitted = emitted | plus: 1 -%}
          {%- endfor -%}
        ]
        {%- endif -%}
      }
    </script>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.trust-signals.name",
  "tag": "section",
  "class": "page-width my-12 md:my-16",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.trust-signals.headings.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.trust-signals.settings.eyebrow.label",
      "default": "Ils nous font confiance"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.trust-signals.settings.title.label",
      "default": "Nos clients adorent leurs tableaux"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.trust-signals.settings.subtitle.label",
      "default": "Découvrez les photos et avis vérifiés de nos clients."
    },
    {
      "type": "header",
      "content": "t:sections.trust-signals.headings.trustpilot"
    },
    {
      "type": "checkbox",
      "id": "show_trustpilot",
      "label": "t:sections.trust-signals.settings.show_trustpilot.label",
      "default": true
    },
    {
      "type": "number",
      "id": "trustpilot_score",
      "label": "t:sections.trust-signals.settings.trustpilot_score.label",
      "info": "t:sections.trust-signals.settings.trustpilot_score.info",
      "default": 45
    },
    {
      "type": "number",
      "id": "trustpilot_review_count",
      "label": "t:sections.trust-signals.settings.trustpilot_review_count.label",
      "default": 1200
    },
    {
      "type": "url",
      "id": "trustpilot_link",
      "label": "t:sections.trust-signals.settings.trustpilot_link.label"
    }
  ],
  "blocks": [
    {
      "type": "image-text",
      "name": "t:sections.trust-signals.blocks.image-text.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.trust-signals.blocks.image-text.settings.image.label"
        },
        {
          "type": "textarea",
          "id": "message",
          "label": "t:sections.trust-signals.blocks.image-text.settings.message.label",
          "default": "Photo magnifique, je suis ravi de mon achat ! Marie L"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.trust-signals.name",
      "blocks": [
        { "type": "image-text" },
        { "type": "image-text" },
        { "type": "image-text" },
        { "type": "image-text" }
      ]
    }
  ]
}
{% endschema %}
