{%- liquid
  assign bg_class = ''
  case section.settings.background
    when 'cream'
      assign bg_class = 'home-section--cream'
    when 'sable'
      assign bg_class = 'home-section--sable'
    when 'dark'
      assign bg_class = 'home-section--dark'
  endcase

  assign align_class = section.settings.align | default: 'center'
-%}

<section class="home-section home-editorial {{ bg_class }} {% if align_class == 'left' %}home-editorial--left{% endif %}">
  <div class="home-editorial__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="home-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <{{ section.settings.heading_level | default: 'h2' }} class="home-h2">{{ section.settings.title | escape }}</{{ section.settings.heading_level | default: 'h2' }}>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="home-lead">{{ section.settings.lead }}</p>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="home-body">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home — Editorial",
  "tag": "section",
  "enabled_on": { "templates": ["index"] },
  "settings": [
    { "type": "select", "id": "background", "label": "Fond", "default": "white",
      "options": [
        { "value": "white", "label": "Blanc" },
        { "value": "cream", "label": "Crème" },
        { "value": "sable", "label": "Sable" },
        { "value": "dark", "label": "Sombre" }
      ]
    },
    { "type": "select", "id": "align", "label": "Alignement", "default": "center",
      "options": [
        { "value": "center", "label": "Centré" },
        { "value": "left", "label": "Gauche" }
      ]
    },
    { "type": "select", "id": "heading_level", "label": "Niveau du titre (SEO)", "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (étiquette)" },
    { "type": "text", "id": "title", "label": "Titre" },
    { "type": "textarea", "id": "lead", "label": "Lead (chapeau, optionnel)" },
    { "type": "richtext", "id": "body", "label": "Corps de texte" }
  ],
  "presets": [{ "name": "Home — Editorial" }]
}
{% endschema %}
