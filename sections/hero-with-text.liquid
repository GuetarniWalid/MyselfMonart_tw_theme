{%- comment -%}
  Home — Hero (split-screen éditorial style Artesta).

  Conventions theme (cf memory feedback) :
  - Tailwind only — pas de CSS custom
  - Variables globales : font-heading, bg-main, text-main-70, bg-secondary
  - Admin-configurable — tout passe par le schema
  - SEO + a11y impeccables — H1 unique, alt obligatoire, focus visible, motion-reduce

  Image responsive : un seul fichier source, srcset avec image_url filter
  (si image_picker rempli), object-position configurable desktop/mobile
  pour un crop responsive propre sans dupliquer l'image. Dimensions
  explicites (width/height) pour éviter le CLS. loading=eager +
  fetchpriority=high pour optimiser LCP.

  Section contrainte au template index via enabled_on.
{%- endcomment -%}

{%- liquid
  assign hero_image = section.settings.hero_image
  assign hero_image_asset = section.settings.hero_image_asset
  assign hero_image_alt = section.settings.hero_image_alt | default: ''

  assign has_uploaded_image = false
  if hero_image != blank
    assign has_uploaded_image = true
  endif

  assign has_asset_image = false
  if hero_image_asset != blank
    assign has_asset_image = true
  endif

  case section.settings.background_color
    when 'cream'
      assign bg_class = 'bg-main-5'
    when 'sable'
      assign bg_class = 'bg-main-10'
    when 'secondary'
      assign bg_class = 'bg-secondary'
    else
      assign bg_class = 'bg-secondary'
  endcase

  assign layout_reverse = false
  if section.settings.layout == 'image-left'
    assign layout_reverse = true
  endif

  assign pos_desktop = section.settings.image_position_desktop | default: 'object-center'
  assign pos_mobile = section.settings.image_position_mobile | default: 'object-center'
-%}

<section
  class="home-hero {{ bg_class }} w-full overflow-hidden"
  aria-labelledby="home-hero-title">
  <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[80vh] lg:min-h-[90vh]">

    {%- comment -%} Bloc texte {%- endcomment -%}
    <div class="col-span-1 lg:col-span-5 flex flex-col justify-center px-6 py-16 md:px-12 md:py-20 lg:px-16 xl:px-24 {% if layout_reverse %}lg:order-2{% else %}lg:order-1{% endif %}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="font-roboto text-xs tracking-[0.2em] uppercase text-main mb-6">
          <span class="title-highlight">{{ section.settings.eyebrow | escape }}</span>
        </p>
      {%- endif -%}

      {%- if section.settings.h1_title != blank -%}
        <h1
          id="home-hero-title"
          class="font-heading text-main !text-4xl md:!text-5xl lg:!text-6xl leading-[1.05] tracking-tight mb-6 md:mb-8">
          {{ section.settings.h1_title }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="font-roboto text-base md:text-lg leading-relaxed text-main-70 max-w-xl mb-8 md:mb-10">
          {{ section.settings.subtitle | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">

          {%- if section.settings.cta_primary_label != blank and section.settings.cta_primary_link != blank -%}
            <a
              href="{{ section.settings.cta_primary_link }}"
              class="inline-flex items-center justify-center gap-3 px-10 py-4 rounded-full bg-main text-secondary font-roboto text-sm font-medium uppercase tracking-[0.08em] transition-colors duration-200 motion-reduce:transition-none hover:bg-main-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-main focus-visible:ring-offset-2 focus-visible:ring-offset-secondary">
              <span>{{ section.settings.cta_primary_label | escape }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_link != blank -%}
            <a
              href="{{ section.settings.cta_secondary_link }}"
              class="inline-flex items-center justify-center gap-3 px-10 py-4 rounded-full bg-transparent border border-main text-main font-roboto text-sm font-medium uppercase tracking-[0.08em] transition-colors duration-200 motion-reduce:transition-none hover:bg-main hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-main focus-visible:ring-offset-2 focus-visible:ring-offset-secondary">
              <span>{{ section.settings.cta_secondary_label | escape }}</span>
            </a>
          {%- endif -%}

        </div>
      {%- endif -%}

    </div>

    {%- comment -%}
      Bloc image — une seule image, optimisée responsive.
      - Si image_picker uploadée : srcset multi-tailles via image_url
        filter (375 → 1800w), browser pick la meilleure.
      - Si asset fallback : src unique avec sizes explicit + object-position
        configurable mobile/desktop pour un crop propre.
    {%- endcomment -%}
    <div class="col-span-1 lg:col-span-7 relative min-h-[60vh] lg:min-h-full {% if layout_reverse %}lg:order-1{% else %}lg:order-2{% endif %}">

      {%- if has_uploaded_image -%}
        <img
          srcset="{%- if hero_image.width >= 375 -%}{{ hero_image | image_url: width: 375 }} 375w,{%- endif -%}
                  {%- if hero_image.width >= 550 -%}{{ hero_image | image_url: width: 550 }} 550w,{%- endif -%}
                  {%- if hero_image.width >= 750 -%}{{ hero_image | image_url: width: 750 }} 750w,{%- endif -%}
                  {%- if hero_image.width >= 1100 -%}{{ hero_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                  {%- if hero_image.width >= 1500 -%}{{ hero_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                  {%- if hero_image.width >= 1800 -%}{{ hero_image | image_url: width: 1800 }} 1800w,{%- endif -%}
                  {{ hero_image | image_url }} {{ hero_image.width }}w"
          sizes="(max-width: 1023px) 100vw, 58vw"
          src="{{ hero_image | image_url: width: 1100 }}"
          alt="{{ hero_image_alt | escape }}"
          width="{{ hero_image.width }}"
          height="{{ hero_image.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover {{ pos_mobile }} md:{{ pos_desktop }}">

      {%- elsif has_asset_image -%}
        {%- assign asset_src = hero_image_asset | asset_url -%}
        <img
          src="{{ asset_src }}"
          alt="{{ hero_image_alt | escape }}"
          width="{{ section.settings.image_asset_width | default: 1024 }}"
          height="{{ section.settings.image_asset_height | default: 1024 }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          sizes="(max-width: 1023px) 100vw, 58vw"
          class="absolute inset-0 w-full h-full object-cover {{ pos_mobile }} md:{{ pos_desktop }}">

      {%- else -%}
        <div class="absolute inset-0 bg-main-10" role="img" aria-label="{% if hero_image_alt != blank %}{{ hero_image_alt | escape }}{% else %}{{ 'sections.mma.hero_image_pending' | t }}{% endif %}"></div>
      {%- endif -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Hero with text",
  "tag": "section",
  "class": "home-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Contenu textuel"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (étiquette stylo au-dessus du H1)",
      "info": "Optionnel. Petite ligne en capitales surlignée (.title-highlight). Ex : « Tableau décoration murale »",
      "default": "Tableau décoration murale"
    },
    {
      "type": "textarea",
      "id": "h1_title",
      "label": "H1 — titre principal",
      "info": "Doit être unique sur la page (la home n'a qu'un seul H1).",
      "default": "Art & décoration murale"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Œuvres curées à la main par notre studio français. Toile 285g, encres archival 75 ans, cadre bois massif."
    },
    {
      "type": "header",
      "content": "Appels à l'action (optionnels)"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "CTA principal — libellé"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "CTA principal — lien"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "CTA secondaire — libellé"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "CTA secondaire — lien"
    },
    {
      "type": "header",
      "content": "Image hero (desktop & mobile)"
    },
    {
      "type": "paragraph",
      "content": "Une seule image servie sur tous les écrans. Recommandation : JPG ou WebP ≤ 300 KB, 1800×1200 minimum, sujet centré pour un crop propre."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero (recommandé — srcset auto)"
    },
    {
      "type": "text",
      "id": "hero_image_asset",
      "label": "OU asset filename (fallback)",
      "info": "Ex : hero-tableau-decoration-murale-salon-v9.jpg (le fichier doit exister dans /assets)."
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Alt text (obligatoire pour SEO et accessibilité)",
      "info": "Décrire le contenu de l'image en 80–125 caractères. Inclure le mot-clé cible sans le forcer.",
      "default": "Tableau décoration murale moderne accroché dans un salon contemporain — MyselfMonArt"
    },
    {
      "type": "number",
      "id": "image_asset_width",
      "label": "Largeur source (px) — pour l'asset fallback",
      "info": "Sert à éviter le CLS. Laisser 1024 si tu ne sais pas.",
      "default": 1024
    },
    {
      "type": "number",
      "id": "image_asset_height",
      "label": "Hauteur source (px) — pour l'asset fallback",
      "default": 1024
    },
    {
      "type": "select",
      "id": "image_position_desktop",
      "label": "Cadrage desktop",
      "default": "object-center",
      "options": [
        { "value": "object-top",    "label": "Haut" },
        { "value": "object-center", "label": "Centre" },
        { "value": "object-bottom", "label": "Bas" },
        { "value": "object-left",   "label": "Gauche" },
        { "value": "object-right",  "label": "Droite" }
      ]
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Cadrage mobile",
      "default": "object-center",
      "options": [
        { "value": "object-top",    "label": "Haut" },
        { "value": "object-center", "label": "Centre" },
        { "value": "object-bottom", "label": "Bas" },
        { "value": "object-left",   "label": "Gauche" },
        { "value": "object-right",  "label": "Droite" }
      ]
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposition desktop",
      "default": "image-right",
      "options": [
        { "value": "image-right", "label": "Texte à gauche, image à droite" },
        { "value": "image-left", "label": "Image à gauche, texte à droite" }
      ]
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Couleur de fond (bloc texte)",
      "default": "secondary",
      "options": [
        { "value": "secondary", "label": "Secondary (par défaut)" },
        { "value": "cream",     "label": "Main 5% (crème)" },
        { "value": "sable",     "label": "Main 10% (sable)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero with text",
      "settings": {
        "eyebrow": "Tableau décoration murale",
        "h1_title": "Art & décoration murale",
        "subtitle": "Œuvres curées à la main par notre studio français."
      }
    }
  ]
}
{% endschema %}
