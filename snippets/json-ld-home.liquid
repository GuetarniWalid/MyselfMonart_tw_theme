{%- comment -%}
  Schemas JSON-LD spécifiques à la home MyselfMonArt.
  Inclus conditionnellement depuis head-base.liquid via :
    {% if request.page_type == 'index' %}{% render 'json-ld-home' %}{% endif %}

  Note : l'Organization schema est déjà injecté par sections/trust-signals.liquid.
  On ne le réinclut pas ici pour éviter le doublon validateur.
{%- endcomment -%}

{%- assign home_url = request.origin | append: '/' -%}
{%- assign logo_url = 'https://cdn.shopify.com/s/files/1/0623/2388/4287/files/logo-myselfmonart-512x512.png?v=1694726914' -%}
{%- if shop.brand.logo -%}
  {%- assign logo_url = shop.brand.logo | image_url: width: 600 -%}
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "@id": "{{ home_url }}#store",
  "name": "MyselfMonArt",
  "image": "{{ logo_url }}",
  "url": "{{ home_url }}",
  "telephone": "+33960446150",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Paris",
    "addressCountry": "FR"
  },
  "priceRange": "€€",
  "areaServed": ["FR", "BE", "CH", "LU", "DE", "ES", "IT", "AT", "PT", "NL", "GB", "US", "CA"],
  "paymentAccepted": ["Credit Card", "PayPal", "Apple Pay", "Google Pay", "Shop Pay"],
  "currenciesAccepted": "EUR",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.1",
    "reviewCount": "80",
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "Accueil",
    "item": "{{ home_url }}"
  }]
}
</script>

