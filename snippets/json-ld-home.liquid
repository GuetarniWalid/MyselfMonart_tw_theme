{%- comment -%}
  Schemas JSON-LD spécifiques à la home MyselfMonArt.
  Inclus conditionnellement depuis head-base.liquid via :
    {% if request.page_type == 'index' %}{% render 'json-ld-home' %}{% endif %}
{%- endcomment -%}

{%- assign home_url = request.origin | append: '/' -%}
{%- assign logo_url = 'https://cdn.shopify.com/s/files/1/0623/2388/4287/files/logo-myselfmonart-512x512.png?v=1694726914' -%}
{%- if shop.brand.logo -%}
  {%- assign logo_url = shop.brand.logo | image_url: width: 600 -%}
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "{{ home_url }}#organization",
  "name": "MyselfMonArt",
  "legalName": "SAS KINDOPIA",
  "url": "{{ home_url }}",
  "logo": {
    "@type": "ImageObject",
    "url": "{{ logo_url }}",
    "width": 600,
    "height": 60
  },
  "foundingDate": "2022",
  "founder": {
    "@type": "Person",
    "name": "Walid",
    "jobTitle": "Directeur artistique, fondateur"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Paris",
    "addressCountry": "FR"
  },
  "contactPoint": [{
    "@type": "ContactPoint",
    "telephone": "+33960446150",
    "contactType": "customer service",
    "areaServed": "FR",
    "availableLanguage": ["French", "English"]
  }],
  "sameAs": [
    "https://fr.trustpilot.com/review/myselfmonart.com"
  ],
  "description": "Studio créatif français spécialisé dans la curation de tableaux décoration murale premium. Direction artistique à Paris, service client à Toulouse, impression européenne."
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "@id": "{{ home_url }}#store",
  "name": "MyselfMonArt",
  "image": "{{ logo_url }}",
  "url": "{{ home_url }}",
  "telephone": "+33960446150",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Paris",
    "addressCountry": "FR"
  },
  "priceRange": "€€",
  "areaServed": ["FR", "BE", "CH", "LU", "DE", "ES", "IT", "AT", "PT", "NL", "GB", "US", "CA"],
  "paymentAccepted": ["Credit Card", "PayPal", "Apple Pay", "Google Pay", "Shop Pay"],
  "currenciesAccepted": "EUR",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.1",
    "reviewCount": "80",
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "Accueil",
    "item": "{{ home_url }}"
  }]
}
</script>

