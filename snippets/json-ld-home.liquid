{%- comment -%}
  Schemas JSON-LD spécifiques à la home MyselfMonArt.
  Inclus conditionnellement depuis head-base.liquid via :
    {% if request.page_type == 'index' %}{% render 'json-ld-home' %}{% endif %}
{%- endcomment -%}

{%- assign home_url = request.origin | append: '/' -%}
{%- comment -%} Featured collections for the ItemList schema. Names pull from each collection's
  own localised title (collections[handle].title) — single source of truth, auto-translated. {%- endcomment -%}
{%- assign featured_handles = 'tableau-salon,tableau-chambre-adulte,tableau-chambre-garcon,tableau-bureau,tableau-cuisine,tableau-abstrait,tableau-zen,tableau-pop-art,tableau-africain,tableau-noir-et-blanc,tableau-fleurs,tableau-japonais,tableaux-frida-kahlo,tableau-paysage,tableau-couleur,tableau-ethnique' | split: ',' -%}
{%- assign logo_url = 'https://cdn.shopify.com/s/files/1/0623/2388/4287/files/logo-myselfmonart-512x512.png?v=1694726914' -%}
{%- if shop.brand.logo -%}
  {%- assign logo_url = shop.brand.logo | image_url: width: 600 -%}
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "{{ home_url }}#organization",
  "name": "MyselfMonArt",
  "legalName": "SAS KINDOPIA",
  "url": "{{ home_url }}",
  "logo": {
    "@type": "ImageObject",
    "url": "{{ logo_url }}",
    "width": 600,
    "height": 60
  },
  "foundingDate": "2022",
  "founder": {
    "@type": "Person",
    "name": "Walid",
    "jobTitle": {{ 'sections.mma.home_founder_jobtitle' | t | json }}
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Paris",
    "addressCountry": "FR"
  },
  "contactPoint": [{
    "@type": "ContactPoint",
    "telephone": "+33960446150",
    "contactType": "customer service",
    "areaServed": "FR",
    "availableLanguage": ["French", "English"]
  }],
  "sameAs": [
    "https://fr.trustpilot.com/review/myselfmonart.com"
  ],
  "description": {{ 'sections.mma.home_org_description' | t | json }}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "@id": "{{ home_url }}#store",
  "name": "MyselfMonArt",
  "image": "{{ logo_url }}",
  "url": "{{ home_url }}",
  "telephone": "+33960446150",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Paris",
    "addressCountry": "FR"
  },
  "priceRange": "€€",
  "areaServed": ["FR", "BE", "CH", "LU", "DE", "ES", "IT", "AT", "PT", "NL", "GB", "US", "CA"],
  "paymentAccepted": ["Credit Card", "PayPal", "Apple Pay", "Google Pay", "Shop Pay"],
  "currenciesAccepted": "EUR"
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": {{ 'sections.mma.breadcrumb_home' | t | json }},
    "item": "{{ home_url }}"
  }]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": "{{ home_url }}#collections-phares",
  "name": {{ 'sections.mma.home_collections_list_name' | t | json }},
  "itemListOrder": "Unordered",
  "numberOfItems": {{ featured_handles.size }},
  "itemListElement": [
    {%- for handle in featured_handles -%}
      {%- assign col = collections[handle] -%}
      {%- unless forloop.first %},{% endunless %}
      {"@type": "ListItem", "position": {{ forloop.index }}, "name": {{ col.title | default: handle | json }}, "url": "{{ home_url }}collections/{{ handle }}"}
    {%- endfor -%}
  ]
}
</script>

{%- comment -%}
  FAQPage JSON-LD : généré dynamiquement par sections/home-faq.liquid à partir
  des blocks (source de vérité unique = blocs admin). Ne pas réintroduire ici
  ou Google verra 2 schémas FAQPage en conflit.

  L'ancien bloc statique (7 questions hardcodées) a été retiré le 2026-05-26.
{%- endcomment -%}
