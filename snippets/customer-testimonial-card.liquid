{% comment %}
    Renders one customer testimonial card (image + message) for the
    customer-testimonial section. All cards are emitted server-side so the
    UGC photos are indexable by Google Image Search.

    Accepts:
      - block: {Object} Section block of type "image-text"
      - forloop: {Object} Forloop object (used for first-card priority hints)
      - theme: {String} 'light' (default — fond clair, texte text-main-90)
                        ou 'dark' (fond sombre, texte text-secondary)
      - image_asset: {String} (optionnel) Filename d'asset si block.settings.image vide

    Usage:
      {% render 'customer-testimonial-card', block: block, forloop: forloop %}
      {% render 'customer-testimonial-card', block: block, forloop: forloop, theme: 'dark' %}
{% endcomment %}

{%- liquid
  assign img = block.settings.image
  assign message = block.settings.message
  assign theme = theme | default: 'light'

  comment
    # Extract the customer name as the last two words of the message.
    # Messages end with a first name + initial (e.g. "...merci. Léa M").
    # Newlines are converted to spaces so a name behind a newline is kept intact.
  endcomment
  assign normalized = message | newline_to_br | replace: '<br />', ' ' | replace: '<br>', ' ' | replace: '  ', ' ' | replace: '  ', ' ' | strip
  assign words = normalized | split: ' '
  assign word_count = words.size
  if word_count >= 2
    assign last_idx = word_count | minus: 1
    assign second_last_idx = word_count | minus: 2
    assign customer_name = words[second_last_idx] | append: ' ' | append: words[last_idx]
  else
    assign customer_name = ''
  endif

  if img.alt != blank
    assign img_alt = img.alt
  elsif customer_name != blank
    assign img_alt = 'sections.mma.photo_shared_by' | t | append: customer_name
  else
    assign img_alt = 'sections.mma.photo_shared_by_customer' | t
  endif

  if forloop.first
    assign loading_strategy = 'eager'
    assign fetch_priority = 'high'
  else
    assign loading_strategy = 'lazy'
    assign fetch_priority = 'auto'
  endif

  comment
    # Theme-dependent classes :
    # - light : fond clair (defaut existant - utilisé par trust-signals)
    # - dark  : fond sombre (utilisé par home-customers sur bg-brand-900)
  endcomment
  if theme == 'dark'
    assign quote_class = 'text-base md:text-lg text-secondary italic leading-relaxed'
    assign author_class = 'mt-3 text-xs tracking-[0.18em] uppercase font-medium text-secondary not-italic'
    assign media_bg_class = 'bg-secondary-50'
  else
    assign quote_class = 'text-base md:text-lg text-main-90 italic leading-relaxed'
    assign author_class = 'mt-3 text-xs tracking-[0.18em] uppercase font-medium text-main-70 not-italic'
    assign media_bg_class = 'bg-main-5'
  endif

  comment
    # Body without the trailing author name (for the dark theme, we display
    # the name on its own line). Light theme keeps the original full-message
    # behavior to avoid breaking trust-signals output.
  endcomment
  assign body_text = normalized
  if theme == 'dark' and customer_name != blank and word_count >= 2
    assign body_size = normalized | size
    assign name_size = customer_name | size
    assign keep = body_size | minus: name_size
    assign body_text = normalized | truncate: keep, '' | strip
    assign body_text = body_text | rstrip
  endif

  comment
    # Image source : prefer image_picker block.settings.image,
    # fallback to block.settings.image_asset asset filename if provided.
  endcomment
  assign asset_url_src = ''
  if img == blank and block.settings.image_asset != blank
    assign asset_url_src = block.settings.image_asset | asset_url
  endif
-%}

<li class="carrousel-item shrink-0 snap-start snap-always w-[83vw] sm:w-[400px]">
  <figure class="testimonial-card flex flex-col gap-4">
    {%- if img != blank -%}
      <div class="testimonial-card__media relative aspect-square w-full overflow-hidden rounded-lg {{ media_bg_class }}">
        <img
          srcset="{%- if img.width >= 400 -%}{{ img | image_url: width: 400 }} 400w,{%- endif -%}
                  {%- if img.width >= 600 -%}{{ img | image_url: width: 600 }} 600w,{%- endif -%}
                  {%- if img.width >= 800 -%}{{ img | image_url: width: 800 }} 800w,{%- endif -%}
                  {{ img | image_url }} {{ img.width }}w"
          src="{{ img | image_url: width: 400 }}"
          sizes="(min-width: 640px) 400px, 83vw"
          alt="{{ img_alt | escape }}"
          loading="{{ loading_strategy }}"
          fetchpriority="{{ fetch_priority }}"
          width="400"
          height="400"
          class="w-full h-full object-cover">
      </div>
    {%- elsif asset_url_src != '' -%}
      <div class="testimonial-card__media relative aspect-square w-full overflow-hidden rounded-lg {{ media_bg_class }}">
        <img
          src="{{ asset_url_src }}"
          alt="{{ img_alt | escape }}"
          loading="{{ loading_strategy }}"
          decoding="async"
          width="400"
          height="400"
          class="w-full h-full object-cover">
      </div>
    {%- endif -%}

    {%- if message != blank -%}
      <figcaption class="testimonial-card__message px-1">
        <blockquote class="{{ quote_class }}">
          {{- body_text | newline_to_br -}}
        </blockquote>
        {%- if theme == 'dark' and customer_name != blank -%}
          <p class="{{ author_class }}">— {{ customer_name }}</p>
        {%- endif -%}
      </figcaption>
    {%- endif -%}
  </figure>
</li>
